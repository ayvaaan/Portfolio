# Example environment file for local development
# Copy this file to `.env` (outside version control) and edit values there.

# Database
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=portfolio_db

# Admin (optional) - set ADMIN_PASSWORD_HASH to the output of PHP's password_hash():
# php -r "echo password_hash('your_password_here', PASSWORD_DEFAULT);"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Optional: restrict CORS to your site URL (e.g., https://example.com)
ALLOWED_ORIGIN=

# Optional: email to receive notifications about new messages
NOTIFY_EMAIL=
